# Fastfile for App Store metadata localization
#
# 3 lanes:
#   precheck_metadata  — PR validation (no upload)
#   push_metadata      — Push text metadata to ASC
#   push_screenshots   — Push screenshots to ASC
#
# Known traps (from Repolog L-FL01~FL07):
#   - precheck: use default_rule_level: :warn only (individual rules cause TypeError)
#   - push_screenshots: set run_precheck_before_submit: false
#   - Don't use sync_screenshots (beta in fastlane 2.232)
#   - deliver download_metadata needs --api_key_path JSON, not ENV vars

default_platform(:ios)

platform :ios do
  # --- Shared: build API key hash from ENV ---
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_KEY_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_P8_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )
  end

  # --- Lane 1: Precheck only (PR validation, no upload) ---
  desc "Validate metadata without uploading"
  lane :precheck_metadata do
    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      precheck_default_rule_level: :warn,
      run_precheck_before_submit: true,
      submit_for_review: false,
      force: true,
    )
  end

  # --- Lane 2: Push text metadata to ASC ---
  desc "Push text metadata (name, description, keywords, etc.) to ASC"
  lane :push_metadata do
    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      precheck_default_rule_level: :warn,
      submit_for_review: false,
      force: true,
    )
  end

  # --- Lane 3: Push screenshots to ASC ---
  desc "Push screenshots to ASC"
  lane :push_screenshots do
    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      force: true,
    )
  end
end
