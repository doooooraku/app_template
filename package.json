{
  "name": "app-factory-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "maestro test maestro/flows/smoke.yml",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "config:check": "node scripts/config-check.mjs",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "verify": "pnpm lint && pnpm type-check && pnpm format:check && pnpm test && pnpm i18n:check && pnpm config:check",
    "prepare": "git config core.hooksPath .githooks",
    "prebuild": "expo prebuild",
    "build:android": "expo prebuild --platform android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.81.1",
    "@tamagui/animations-react-native": "1.138.5",
    "@tamagui/core": "1.138.5",
    "@tamagui/lucide-icons": "1.138.5",
    "@tamagui/portal": "1.138.5",
    "@tanstack/react-query": "^5.90.10",
    "dotenv": "^17.2.3",
    "expo": "~54.0.27",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "~18.0.11",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.10",
    "expo-localization": "~17.0.8",
    "expo-notifications": "^0.32.14",
    "expo-router": "~6.0.17",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.7",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~55.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.0",
    "react-native-purchases": "^9.6.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tamagui": "1.138.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.82.1",
    "@tamagui/babel-plugin": "1.138.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.14",
    "lint-staged": "^16.1.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!src/core/i18n/locales/**",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 20
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|@tanstack/.*|zustand|@supabase/.*|tamagui|@tamagui/.*)"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
