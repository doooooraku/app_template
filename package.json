{
  "name": "app-factory-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "maestro test maestro/flows/smoke.yml",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "config:check": "node scripts/config-check.mjs",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "verify": "pnpm lint && pnpm type-check && pnpm format:check && pnpm test && pnpm i18n:check && pnpm config:check",
    "prepare": "git config core.hooksPath .githooks",
    "prebuild": "expo prebuild",
    "build:android": "expo prebuild --platform android && cd android && ./gradlew bundleRelease",
    "build:android:apk:local": "node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile development --local --output dist/app-dev.apk && node scripts/postbuild-verify.mjs dist/app-dev.apk",
    "build:android:aab:local": "node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile production --local --output dist/app-production.aab && node scripts/postbuild-verify.mjs dist/app-production.aab",
    "metadata:check": "node scripts/validate-metadata.mjs",
    "dev:android": "bash scripts/dev-start.sh",
    "ump:check": "node scripts/ump-consent-check.mjs",
    "debug:start": "bash scripts/debug/debug_session.sh start",
    "debug:stop": "bash scripts/debug/debug_session.sh stop",
    "debug:status": "bash scripts/debug/debug_session.sh status",
    "monitor": "bash scripts/debug/monitor.sh"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.0.2",
    "@tamagui/animations-react-native": "1.144.3",
    "@tamagui/core": "1.144.3",
    "@tamagui/lucide-icons": "1.144.3",
    "@tamagui/portal": "1.144.3",
    "@tanstack/react-query": "^5.90.10",
    "dotenv": "^17.2.3",
    "expo": "~55.0.9",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-notifications": "^55.0.14",
    "expo-router": "~55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~55.0.13",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.9",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.85.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-google-mobile-ads": "^16.3.2",
    "react-native-purchases": "^9.15.2",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.8.1",
    "tamagui": "1.144.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.85.0",
    "@tamagui/babel-plugin": "1.144.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.11",
    "lint-staged": "^16.1.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!src/core/i18n/locales/**",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 20
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|@tanstack/.*|zustand|tamagui|@tamagui/.*)"
    ]
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true
}
